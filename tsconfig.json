{
  "compilerOptions": {
    "target": "es2020",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "strict": true,
    "moduleResolution": "bundler",
    "sourceMap": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "esModuleInterop": true,
    "types": ["chrome", "jest"]
  },
  "include": ["**/*.ts"],
  "exclude": [".git", "dist", "node_modules"],
  "compileOnSave": false
}
